generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum PaymentMethod {
  CASH
}

enum InvoiceStatus {
  COMPLETED
  VOIDED
}

enum ExpenseCategory {
  RENT
  SALARIES
  ELECTRICITY
  WATER
  INTERNET
  MAINTENANCE
  MARKETING
  DELIVERY
  EQUIPMENT
  OTHER
}

enum ExpenseFrequency {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  RECURRING
}

enum PayrollStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model Branch {
  id        String    @id @default(cuid())
  name      String
  nameAr    String
  code      String    @unique
  address   String?
  active    Boolean   @default(true)
  users     User[]
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  active       Boolean    @default(true)
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  invoices     Invoice[]  @relation("CashierInvoices")
  expenses     OperatingExpense[]
  auditLogs    AuditLog[]
  baseSalary   Decimal    @default(0) @db.Decimal(12, 2)
  payrollRecords PayrollRecord[] @relation("EmployeePayroll")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Category {
  id           String             @id @default(cuid())
  nameEn       String
  nameAr       String
  active       Boolean            @default(true)
  sortOrder    Int                @default(0)
  products     Product[]
  discounts    DiscountCampaign[] @relation("DiscountCategories")
  invoiceItems InvoiceItem[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Product {
  id           String               @id @default(cuid())
  sku          String               @unique
  price        Decimal              @db.Decimal(10, 2)
  currentCost  Decimal              @default(0) @db.Decimal(10, 2)
  imageUrl     String?
  active       Boolean              @default(true)
  categoryId   String
  category     Category             @relation(fields: [categoryId], references: [id])
  translations ProductTranslation[]
  sizes        ProductSize[]
  addons       ProductAddon[]
  ingredients  ProductIngredient[]
  discounts    DiscountCampaign[]   @relation("DiscountProducts")
  invoiceItems InvoiceItem[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ProductTranslation {
  id          String  @id @default(cuid())
  locale      String
  name        String
  description String?
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductSize {
  id         String  @id @default(cuid())
  nameEn     String
  nameAr     String
  priceDelta Decimal @db.Decimal(10, 2)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductAddon {
  id        String  @id @default(cuid())
  nameEn    String
  nameAr    String
  price     Decimal @db.Decimal(10, 2)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id           String              @id @default(cuid())
  nameEn       String
  nameAr       String
  unit         String
  purchaseCost Decimal             @db.Decimal(10, 4)
  purchaseQty  Decimal             @db.Decimal(10, 4)
  unitCost     Decimal             @db.Decimal(10, 4)
  active       Boolean             @default(true)
  products     ProductIngredient[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model ProductIngredient {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantityUsed Decimal    @db.Decimal(10, 4)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([productId, ingredientId])
}

model OperatingExpense {
  id          String           @id @default(cuid())
  title       String
  category    ExpenseCategory
  frequency   ExpenseFrequency @default(ONE_TIME)
  amount      Decimal          @db.Decimal(12, 2)
  expenseDate DateTime
  notes       String?
  active      Boolean          @default(true)
  branchId    String?
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  invoiceName String?
  invoiceUrl  String?
  payrollRecord PayrollRecord? @relation(fields: [payrollRecordId], references: [id])
  payrollRecordId String? @unique

  @@index([expenseDate, category])
}

model PayrollRecord {
  id            String        @id @default(cuid())
  employeeId    String
  employee      User          @relation("EmployeePayroll", fields: [employeeId], references: [id])
  payrollMonth  DateTime
  baseSalary    Decimal       @db.Decimal(12, 2)
  overtime      Decimal       @default(0) @db.Decimal(12, 2)
  bonuses       Decimal       @default(0) @db.Decimal(12, 2)
  deductions    Decimal       @default(0) @db.Decimal(12, 2)
  advances      Decimal       @default(0) @db.Decimal(12, 2)
  netSalary     Decimal       @db.Decimal(12, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(12, 2)
  status        PayrollStatus @default(UNPAID)
  approved      Boolean       @default(false)
  paymentDate   DateTime?
  expense       OperatingExpense?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([employeeId, payrollMonth])
  @@index([payrollMonth, status])
}

model DiscountCampaign {
  id         String       @id @default(cuid())
  nameEn     String
  nameAr     String
  type       DiscountType
  value      Decimal      @db.Decimal(10, 2)
  startsAt   DateTime
  endsAt     DateTime
  active     Boolean      @default(true)
  products   Product[]    @relation("DiscountProducts")
  categories Category[]   @relation("DiscountCategories")
  invoices   Invoice[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Invoice {
  id             String            @id @default(cuid())
  number         String            @unique
  status         InvoiceStatus     @default(COMPLETED)
  subtotal       Decimal           @db.Decimal(12, 2)
  discountAmount Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal           @db.Decimal(12, 2)
  paymentMethod  PaymentMethod     @default(CASH)
  cashierId      String
  cashier        User              @relation("CashierInvoices", fields: [cashierId], references: [id])
  branchId       String
  branch         Branch            @relation(fields: [branchId], references: [id])
  discountId     String?
  discount       DiscountCampaign? @relation(fields: [discountId], references: [id])
  items          InvoiceItem[]
  payment        Payment?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([createdAt, branchId])
  @@index([cashierId])
}

model InvoiceItem {
  id                   String             @id @default(cuid())
  invoiceId            String
  invoice              Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId            String?
  product              Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  categoryId           String?
  category             Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productNameSnapshot  String
  quantity             Int
  unitPrice            Decimal            @db.Decimal(10, 2)
  selectedSizeSnapshot String?
  totalPrice           Decimal            @db.Decimal(12, 2)
  unitCostSnapshot     Decimal            @default(0) @db.Decimal(10, 2)
  totalCostSnapshot    Decimal            @default(0) @db.Decimal(12, 2)
  addons               InvoiceItemAddon[]
}

model InvoiceItemAddon {
  id            String      @id @default(cuid())
  invoiceItemId String
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  nameSnapshot  String
  priceSnapshot Decimal     @db.Decimal(10, 2)
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String        @unique
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  method    PaymentMethod @default(CASH)
  amount    Decimal       @db.Decimal(12, 2)
  paidAt    DateTime      @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
